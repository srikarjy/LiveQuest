# Copy to .env and fill in. Only ANTHROPIC_API_KEY is required for a live run.
ANTHROPIC_API_KEY=

# Neo4j (defaults match docker-compose)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=bioquest-dev

# false = deterministic offline demo from committed seed fixtures
# true  = hit public PubMed E-utilities + Open Targets GraphQL APIs
USE_LIVE_DATA=false
